{
  "builds": [
    {
      "src": "api/generate.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 60 }
    },
    {
      "src": "api/lookup.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 15 }
    },
    {
      "src": "api/volatility.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 30 }
    },
    {
      "src": "api/extract_beta.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 30 }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/generate", "dest": "/api/generate.py" },
    { "src": "/api/lookup", "dest": "/api/lookup.py" },
    { "src": "/api/volatility", "dest": "/api/volatility.py" },
    { "src": "/api/extract-beta", "dest": "/api/extract_beta.py" },
    {
      "src": "/(.*)",
      "dest": "/public/$1",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }
    }
  ]
}
